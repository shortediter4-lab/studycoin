<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>StudyCoin Login</title>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: Arial, sans-serif;
    }

    html, body {
      height: 100%;
      width: 100%;
    }

    body {
      display: flex;
      justify-content: center;
      align-items: center;
      background: linear-gradient(135deg, #141e30, #243b55);
    }

    .login {
      width: 340px;
      padding: 30px;
      border-radius: 15px;
      background: white;
      text-align: center;
      box-shadow: 0 20px 50px rgba(0,0,0,0.4);
    }

    .login h2 {
      margin-bottom: 20px;
      color: #243b55;
    }

    input {
      width: 100%;
      padding: 12px;
      margin: 10px 0;
      border: 1px solid #ccc;
      border-radius: 8px;
      outline: none;
    }

    button {
      width: 100%;
      padding: 12px;
      margin-top: 10px;
      border: none;
      border-radius: 8px;
      background: #243b55;
      color: white;
      font-size: 16px;
      cursor: pointer;
    }

    button:hover {
      background: #141e30;
    }
  </style>
</head>

<body>

  <div class="login">
    <h2>🔐 StudyCoin Login</h2>

    <input type="email" id="email" placeholder="Email">
    <input type="password" id="password" placeholder="Password">

    <button id="loginBtn">Login</button>
  </div>

</body>
</html>
